# Optional: portfolio visit counter (Supabase).
# Copy to ".env" for local dev. For Vercel/Netlify/Cloudflare, set these in the host UI (same names).
#
# Use Project Settings → API in Supabase:
#   - URL → VITE_SUPABASE_URL
#   - anon public key → VITE_SUPABASE_ANON_KEY
#
# Do NOT put the service_role secret here — it must never ship to the browser.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
